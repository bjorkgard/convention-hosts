# =============================================================================
# Application Configuration
# =============================================================================
APP_NAME="Convention Hosts"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE="Europe/Stockholm"

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

# =============================================================================
# Security
# =============================================================================
BCRYPT_ROUNDS=12

# =============================================================================
# Logging
# =============================================================================
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================================
# Database Configuration
# =============================================================================
# Default: SQLite (no additional config needed)
# The database file is at database/database.sqlite
DB_CONNECTION=sqlite

# For MySQL, uncomment and configure:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=convention_hosts
# DB_USERNAME=root
# DB_PASSWORD=

# For PostgreSQL, uncomment and configure:
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=convention_hosts
# DB_USERNAME=root
# DB_PASSWORD=

# =============================================================================
# Session Configuration
# =============================================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# =============================================================================
# Queue, Cache, and Broadcasting
# =============================================================================
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# =============================================================================
# Redis (optional, for cache/queue/session)
# =============================================================================
MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================================================
# Mail Configuration (Mailgun)
# =============================================================================
# The application uses Mailgun for sending invitation and confirmation emails.
# For local development, change MAIL_MAILER to "log" to write emails to storage/logs.
MAIL_MAILER=mailgun
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@conventionmanager.app"
MAIL_FROM_NAME="${APP_NAME}"

# Mailgun credentials (required for email delivery)
# Sign up at https://www.mailgun.com and add your domain + API key below.
MAILGUN_DOMAIN=
MAILGUN_SECRET=
MAILGUN_ENDPOINT=api.mailgun.net

# =============================================================================
# AWS (optional, not required for core functionality)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# =============================================================================
# Frontend / Vite
# =============================================================================
VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# GitHub Release Version Tracking
# =============================================================================
GITHUB_REPO="bjorkgard/convention-hosts"
