{
  "enabled": true,
  "name": "Lint PHP on Save",
  "description": "Runs Laravel Pint on PHP files when they are saved",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*.php"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "./vendor/bin/pint \"$KIRO_FILE_PATH\"",
    "timeout": 30
  }
}